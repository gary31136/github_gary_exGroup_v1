":[]},{"code":102,"indent":1,"parameters":[["好，我想知道"],-1,0,2,0]},{"code":402,"indent":1,"parameters":[0,"好，我想知道"]},{"code":105,"indent":2,"parameters":[4,false]},{"code":405,"indent":2,"parameters":["郭懷一事件發生於 1652 年，是荷蘭統治臺灣時期規模最大的漢人"]},{"code":405,"indent":2,"parameters":["反抗行動之一。當時荷蘭東印度公司為了發展殖民貿易與農業，鼓"]},{"code":405,"indent":2,"parameters":["勵大量漢人移民來臺開墾，種植許多的稻米與甘蔗，並且這些漢人"]},{"code":405,"indent":2,"parameters":["也必須聽從荷蘭人的命令，還要依規定繳納沉重的稅金。（如人頭"]},{"code":405,"indent":2,"parameters":["稅）。"]},{"code":231,"indent":2,"parameters":[1,"郭懷一故事1",1,0,400,296,100,100,255,0]},{"code":112,"indent":2,"parameters":[]},{"code":102,"indent":3,"parameters":[["看完了"],-1,0,2,0]},{"code":402,"indent":3,"parameters":[0,"看完了"]},{"code":235,"indent":4,"parameters":[1]},{"code":113,"indent":4,"parameters":[]},{"code":0,"indent":4,"parameters":[]},{"code":404,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":413,"indent":2,"parameters":[]},{"code":105,"indent":2,"parameters":[4,false]},{"code":405,"indent":2,"parameters":["此外，荷蘭人實施嚴格的居住與經濟管制，加上部分荷蘭士兵與官"]},{"code":405,"indent":2,"parameters":["吏存在勒索與腐敗行為，使農民生活壓力日益加重，民怨逐漸累積。"]},{"code":231,"indent":2,"parameters":[2,"郭懷一故事2",0,0,192,120,100,100,255,0]},{"code":112,"indent":2,"parameters":[]},{"code":102,"indent":3,"parameters":[["看完了"],-1,0,2,0]},{"code":402,"indent":3,"parameters":[0,"看完了"]},{"code":235,"indent":4,"parameters":[2]},{"code":113,"indent":4,"parameters":[]},{"code":0,"indent":4,"parameters":[]},{"code":404,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":413,"indent":2,"parameters":[]},{"code":105,"indent":2,"parameters":[4,false]},{"code":405,"indent":2,"parameters":["最後，西元1652年，來自泉州的農民領袖郭懷一號召數千名農民起"]},{"code":405,"indent":2,"parameters":["兵反抗，原計畫於特定節日發動，但因消息外洩而提前行動，率領"]},{"code":405,"indent":2,"parameters":["農民攻擊荷蘭據點並一度取得優勢。然而農民軍多以農具與簡易武"]},{"code":405,"indent":2,"parameters":["器作戰，最終在荷蘭軍隊的火器與部分原住民盟軍的支援下遭到擊"]},{"code":405,"indent":2,"parameters":["敗，起義僅持續數日即被鎮壓，郭懷一亦在戰亂中身亡，約有數千"]},{"code":405,"indent":2,"parameters":["名農民犧牲。"]},{"code":231,"indent":2,"parameters":[3,"郭懷一故事3",0,0,-8,120,100,100,255,0]},{"code":112,"indent":2,"parameters":[]},{"code":102,"indent":3,"parameters":[["看完了"],-1,0,2,0]},{"code":402,"indent":3,"parameters":[0,"看完了"]},{"code":235,"indent":4,"parameters":[3]},{"code":113,"indent":4,"parameters":[]},{"code":0,"indent":4,"parameters":[]},{"code":404,"indent":3,"parameters":[]},{"code":0,"indent":3,"parameters":[]},{"code":413,"indent":2,"parameters":[]},{"code":101,"indent":2,"parameters":["Evil",7,0,2,"書精靈"]},{"code":401,"indent":2,"parameters":["這就是郭懷一事件的始末!"]},{"code":101,"indent":2,"parameters":["Evil",7,0,2,"書精靈"]},{"code":401,"indent":2,"parameters":["如果你剛剛沒有看清楚，你可以去詢問時空引導員，"]},{"code":401,"indent":2,"parameters":["跟時空引導員說你想要知道郭懷一相關的事。"]},{"code":101,"indent":2,"parameters":["Actor1",0,0,2,"張濤"]},{"code":401,"indent":2,"parameters":["原來是這樣啊!"]},{"code":401,"indent":2,"parameters":["而且從我收集到的資料來看，每一個族群對這件事"]},{"code":401,"indent":2,"parameters":["的看法真的都不一樣，我們不能用某一個立場就認"]},{"code":401,"indent":2,"parameters":["為一定是這樣。"]},{"code":101,"indent":2,"parameters":["Actor1",0,0,2,"張濤"]},{"code":401,"indent":2,"parameters":["我還要再多思考呢!"]},{"code":101,"indent":2,"parameters":["Evil",7,0,2,"書精靈"]},{"code":401,"indent":2,"parameters":["沒錯，你能這樣想真的太好了!"]},{"code":101,"indent":2,"parameters":["Evil",7,0,2,"書精靈"]},{"code":401,"indent":2,"parameters":["看看時間，你也準備要醒了，希望你能繼續努力下去，早點回到"]},{"code":401,"indent":2,"parameters":["你本來的世界!"]},{"code":121,"indent":2,"parameters":[18,18,0]},{"code":113,"indent":2,"parameters":[]},{"code":0,"indent":2,"parameters":[]},{"code":404,"indent":1,"parameters":[]},{"code":0,"indent":1,"parameters":[]},{"code":413,"indent":0,"parameters":[]},{"code":201,"indent":0,"parameters":[0,17,15,7,0,0]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"thr